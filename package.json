{
  "name": "autoaidev",
  "displayName": "AutoAIDev",
  "description": "Autonomous AI task loop: reads TODO.md, sends tasks to Claude or Copilot (UI or CLI), tracks progress, supports session resume, Discord, and webhooks",
  "version": "1.0.0",
  "publisher": "AutoAIDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/autoaidev/autodev-vscode-extension"
  },
  "homepage": "https://github.com/autoaidev/autodev-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/autoaidev/autodev-vscode-extension/issues"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "claude", "copilot", "opencode", "autonomous", "agent", "todo", "task", "loop", "automation"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autodev-sidebar",
          "title": "AutoDev AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "autodev-sidebar": [
        {
          "type": "webview",
          "id": "autodev.chatStatus",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "autodev.startTaskLoop",
        "title": "AutoDev: Start Task Loop",
        "icon": "$(play)"
      },
      {
        "command": "autodev.stopTaskLoop",
        "title": "AutoDev: Stop Task Loop",
        "icon": "$(stop)"
      },
      {
        "command": "autodev.openSettings",
        "title": "AutoDev: Open Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "autodev.startTaskLoop",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        },
        {
          "command": "autodev.stopTaskLoop",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        },
        {
          "command": "autodev.openSettings",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.99.0",
    "typescript": "^5.8.0"
  }
}
