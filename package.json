{
  "name": "autodev-vscode-extension",
  "displayName": "AutoDev",
  "description": "Autonomous AI task loop: reads TODO.md, sends tasks to Copilot or Claude, tracks progress",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autodev-sidebar",
          "title": "AutoDev AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "autodev-sidebar": [
        {
          "type": "webview",
          "id": "autodev.chatStatus",
          "name": "Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "autodev.startTaskLoop",
        "title": "AutoDev: Start Task Loop",
        "icon": "$(play)"
      },
      {
        "command": "autodev.stopTaskLoop",
        "title": "AutoDev: Stop Task Loop",
        "icon": "$(stop)"
      },
      {
        "command": "autodev.openSettings",
        "title": "AutoDev: Open Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "autodev.startTaskLoop",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        },
        {
          "command": "autodev.stopTaskLoop",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        },
        {
          "command": "autodev.openSettings",
          "when": "view == autodev.chatStatus",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.99.0",
    "typescript": "^5.8.0"
  }
}
